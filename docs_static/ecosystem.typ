#block(inset: (left: 20pt), below: 0.2em)[#text(size: 9pt, style: "italic", fill: rgb("#4a5568"))[Native Android apps that serve as frontends for interacting with agents on mobile.]]
#block(inset: (left: 20pt), below: 0.3em)[#text(size: 8.5pt, fill: rgb("#2d3748"))[Android-specific client applications for chatting with and operating agents from a phone. Handles mobile UX, background behaviour, and on-device integrations distinct from web or desktop clients.]]
#block(inset: (left: 20pt), below: 0.4em)[#text(size: 8.5pt, fill: rgb("#2f855a"))[*Examples:* Operit]]
