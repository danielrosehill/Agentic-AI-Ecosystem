#block(inset: (left: 20pt), below: 0.2em)[#text(size: 9pt, style: "italic", fill: rgb("#4a5568"))[Terminal user interfaces and command-line clients for interacting with agents.]]
#block(inset: (left: 20pt), below: 0.3em)[#text(size: 8.5pt, fill: rgb("#2d3748"))[Text-mode frontends — TUIs and CLIs — for driving agents from the terminal. Favoured by developers for scriptability, low overhead, and integration into shell workflows.]]
#block(inset: (left: 20pt), below: 0.4em)[#text(size: 8.5pt, fill: rgb("#2f855a"))[*Examples:* Agent Deck]]
