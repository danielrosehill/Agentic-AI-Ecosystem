digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Financial Tools", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:financial-tools" [label="Financial Tools", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Agent-oriented tools targeted at financial workflows."];
  "proj:goat" [label="GOAT", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/goat-sdk/goat", URL="https://github.com/goat-sdk/goat"];
  "proj:agentkit" [label="AgentKit", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/coinbase/agentkit", URL="https://github.com/coinbase/agentkit"];
  "cat:financial-tools" -> "proj:goat";
  "cat:financial-tools" -> "proj:agentkit";
}