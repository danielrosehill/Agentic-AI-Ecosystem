digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Operations", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:operations" [label="Operations", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Operational concerns for running agents in production — cost, monitoring, reliability."];
  "cat:operations/cost-monitoring" [label="Cost Monitoring", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:agentops" [label="AgentOps", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/AgentOps-AI/agentops", URL="https://github.com/AgentOps-AI/agentops"];
  "cat:operations" -> "cat:operations/cost-monitoring";
  "cat:operations/cost-monitoring" -> "proj:agentops";
}