digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Synthesised Perspectives", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:synthesised-perspectives" [label="Synthesised Perspectives", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Tools that synthesise multiple viewpoints or agent outputs into a unified perspective."];
  "proj:plurals" [label="Plurals", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/josh-ashkinaze/plurals", URL="https://github.com/josh-ashkinaze/plurals"];
  "proj:llm-council" [label="llm-council", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/karpathy/llm-council", URL="https://github.com/karpathy/llm-council"];
  "cat:synthesised-perspectives" -> "proj:plurals";
  "cat:synthesised-perspectives" -> "proj:llm-council";
}