digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Societal Simulations", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:societal-simulations" [label="Societal Simulations", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Large-scale simulations of societies and human behaviour using agent populations."];
  "proj:oasis" [label="OASIS", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/camel-ai/oasis", URL="https://github.com/camel-ai/oasis"];
  "cat:societal-simulations" -> "proj:oasis";
}