digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Engineering Platforms", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:engineering-platforms" [label="Engineering Platforms", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Platforms targeted at engineering teams building with LLMs and agents."];
  "proj:voltagent" [label="voltagent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/VoltAgent/voltagent", URL="https://github.com/VoltAgent/voltagent"];
  "cat:engineering-platforms" -> "proj:voltagent";
}