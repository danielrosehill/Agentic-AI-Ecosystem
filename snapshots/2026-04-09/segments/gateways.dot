digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Gateways", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:gateways" [label="Gateways", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Gateway services that sit between agents and upstream services (LLMs, tools, data)."];
  "cat:gateways/context-compression" [label="Context Compression", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:context-gateway" [label="Context-Gateway", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Compresr-ai/Context-Gateway", URL="https://github.com/Compresr-ai/Context-Gateway"];
  "cat:gateways" -> "cat:gateways/context-compression";
  "cat:gateways/context-compression" -> "proj:context-gateway";
}