digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Agents", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:agents" [label="Agents", shape=circle, fillcolor="#1f6feb", width=1.69, height=1.69, fontsize=11, tooltip="General agent projects and agent subtypes that do not fit more specific segments."];
  "proj:xataio-agent" [label="xataio/agent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/xataio/agent", URL="https://github.com/xataio/agent"];
  "cat:agents/autonomous" [label="Autonomous", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:agents/autonomous/trading" [label="Trading", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:ai-trader" [label="AI-Trader", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/HKUDS/AI-Trader", URL="https://github.com/HKUDS/AI-Trader"];
  "cat:agents/autonomous-agent-creation" [label="Autonomous Agent Creation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:bankrbot-skills" [label="BankrBot/skills", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/BankrBot/skills", URL="https://github.com/BankrBot/skills"];
  "cat:agents/backend-platforms" [label="Backend Platforms", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:dify" [label="dify", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/langgenius/dify", URL="https://github.com/langgenius/dify"];
  "cat:agents/clis-toolkits" [label="CLIs/Toolkits", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:agents/clis-toolkits/vendor" [label="Vendor", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:qwen-code" [label="qwen-code", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/QwenLM/qwen-code", URL="https://github.com/QwenLM/qwen-code"];
  "cat:agents/computer-use" [label="Computer Use", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Agents and frameworks that operate a computer the way a human would (mouse, keyboard, screen)."];
  "proj:open-computer-use" [label="open-computer-use", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/coasty-ai/open-computer-use", URL="https://github.com/coasty-ai/open-computer-use"];
  "cat:agents/development" [label="Development", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:openhands" [label="OpenHands", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/OpenHands/OpenHands", URL="https://github.com/OpenHands/OpenHands"];
  "cat:agents/domain-specific" [label="Domain Specific", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:agents/domain-specific/biotech" [label="Biotech", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:biomni" [label="Biomni", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/snap-stanford/Biomni", URL="https://github.com/snap-stanford/Biomni"];
  "cat:agents/frameworks" [label="Frameworks", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="General-purpose frameworks for building agents and agentic applications."];
  "cat:agents/frameworks/open-source" [label="Open Source", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:hermes-agent" [label="hermes-agent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/NousResearch/hermes-agent", URL="https://github.com/NousResearch/hermes-agent"];
  "cat:agents/frontends" [label="Frontends", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="User-facing interfaces — web, desktop, mobile, terminal — for interacting with agents."];
  "proj:openclaw-mission-control" [label="openclaw-mission-control", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/abhi1693/openclaw-mission-control", URL="https://github.com/abhi1693/openclaw-mission-control"];
  "cat:agents/harnesses" [label="Harnesses", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Test harnesses and runner frameworks that host and exercise agents."];
  "cat:agents/harnesses/clis" [label="CLIs", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip=""];
  "cat:agents/harnesses/clis/third-party" [label="Third Party", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:crush" [label="crush", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/charmbracelet/crush", URL="https://github.com/charmbracelet/crush"];
  "cat:agents/harnesses/clis/vendor" [label="Vendor", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:gemini-cli" [label="gemini-cli", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/google-gemini/gemini-cli", URL="https://github.com/google-gemini/gemini-cli"];
  "cat:agents/memory" [label="Memory", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Memory systems for agents — short-term, long-term, episodic, file-backed, graph-backed."];
  "cat:agents/memory/graph-builders" [label="Graph Builders", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:graphiti" [label="graphiti", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/getzep/graphiti", URL="https://github.com/getzep/graphiti"];
  "cat:agents/personal-focused" [label="Personal Focused", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:crucix" [label="Crucix", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/calesthio/Crucix", URL="https://github.com/calesthio/Crucix"];
  "cat:agents/purpose-specific" [label="Purpose Specific", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip=""];
  "proj:inkos" [label="inkos", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Narcooo/inkos", URL="https://github.com/Narcooo/inkos"];
  "cat:agents/purpose-specific/penetration-testing" [label="Penetration Testing", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:pentagi" [label="pentagi", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/vxcontrol/pentagi", URL="https://github.com/vxcontrol/pentagi"];
  "cat:agents/team-formation" [label="Team Formation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:squad" [label="squad", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/bradygaster/squad", URL="https://github.com/bradygaster/squad"];
  "cat:agents/teams" [label="Teams", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:ai-data-science-team" [label="ai-data-science-team", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/business-science/ai-data-science-team", URL="https://github.com/business-science/ai-data-science-team"];
  "cat:agents/vision" [label="Vision", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:vision-agents" [label="Vision-Agents", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/GetStream/Vision-Agents", URL="https://github.com/GetStream/Vision-Agents"];
  "cat:agents" -> "proj:xataio-agent";
  "cat:agents" -> "cat:agents/autonomous";
  "cat:agents/autonomous" -> "cat:agents/autonomous/trading";
