  "cat:agents" -> "cat:agents/memory";
  "cat:agents/memory" -> "cat:agents/memory/graph-builders";
  "cat:agents/memory/graph-builders" -> "proj:graphiti";
  "cat:agents" -> "cat:agents/personal-focused";
