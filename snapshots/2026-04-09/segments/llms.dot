digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="LLMs", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:llms" [label="LLMs", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Language models, including those trained or tuned specifically for agentic use cases."];
  "proj:gemini-3-1" [label="Gemini 3.1", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip=""];
  "cat:llms/agent-specific" [label="Agent Specific", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:grok-4-20-multi-agent" [label="Grok 4.20 Multi-Agent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://openrouter.ai/x-ai/grok-4.20-multi-agent", URL="https://openrouter.ai/x-ai/grok-4.20-multi-agent"];
  "cat:llms/by-use-case" [label="By Use Case", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:llms/by-use-case/computer-use" [label="Computer Use", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Agents and frameworks that operate a computer the way a human would (mouse, keyboard, screen)."];
  "proj:fara" [label="Fara", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/microsoft/fara", URL="https://github.com/microsoft/fara"];
  "cat:llms" -> "proj:gemini-3-1";
  "cat:llms" -> "cat:llms/agent-specific";
  "cat:llms/agent-specific" -> "proj:grok-4-20-multi-agent";
  "cat:llms" -> "cat:llms/by-use-case";
  "cat:llms/by-use-case" -> "cat:llms/by-use-case/computer-use";
  "cat:llms/by-use-case/computer-use" -> "proj:fara";
}