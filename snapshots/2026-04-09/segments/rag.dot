digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="RAG", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:rag" [label="RAG", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Retrieval-augmented generation engines, frameworks and components."];
  "proj:airweave" [label="Airweave", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/airweave-ai/airweave", URL="https://github.com/airweave-ai/airweave"];
  "cat:rag/engines" [label="Engines", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:ragflow" [label="RAGFlow", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/infiniflow/ragflow", URL="https://github.com/infiniflow/ragflow"];
  "proj:agent-reach" [label="Agent-Reach", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Panniantong/Agent-Reach", URL="https://github.com/Panniantong/Agent-Reach"];
  "cat:rag/ingestion" [label="Ingestion", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Pipelines that ingest and process documents into retrieval systems."];
  "cat:rag" -> "proj:airweave";
  "cat:rag" -> "cat:rag/engines";
  "cat:rag/engines" -> "proj:ragflow";
  "cat:rag/ingestion" -> "proj:agent-reach";
  "cat:rag" -> "cat:rag/ingestion";
}