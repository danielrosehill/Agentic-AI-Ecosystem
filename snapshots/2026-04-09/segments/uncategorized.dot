digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Uncategorized", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:uncategorized" [label="Uncategorized", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Holding area for projects awaiting classification. Entries here are a todo list, not a destination."];
  "proj:agency-agents" [label="agency-agents", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/msitarzewski/agency-agents", URL="https://github.com/msitarzewski/agency-agents"];
  "cat:uncategorized" -> "proj:agency-agents";
}