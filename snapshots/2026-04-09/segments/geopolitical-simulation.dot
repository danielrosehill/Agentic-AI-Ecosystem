digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Geopolitical Simulation", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:geopolitical-simulation" [label="Geopolitical Simulation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Simulations focused specifically on geopolitical scenarios and dynamics."];
  "proj:wargamesai" [label="WargamesAI", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/user1342/WargamesAI", URL="https://github.com/user1342/WargamesAI"];
  "proj:snowglobe" [label="snowglobe", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/IQTLabs/snowglobe", URL="https://github.com/IQTLabs/snowglobe"];
  "cat:geopolitical-simulation" -> "proj:wargamesai";
  "cat:geopolitical-simulation" -> "proj:snowglobe";
}