digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Browser Tooling", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:browser-tooling" [label="Browser Tooling", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Utilities and SDKs that sit alongside browsers to support agentic workflows."];
  "proj:agent-browser" [label="Agent Browser", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/vercel-labs/agent-browser", URL="https://github.com/vercel-labs/agent-browser"];
  "proj:stagehand" [label="Stagehand", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/browserbase/stagehand", URL="https://github.com/browserbase/stagehand"];
  "cat:browser-tooling" -> "proj:agent-browser";
  "cat:browser-tooling" -> "proj:stagehand";
}