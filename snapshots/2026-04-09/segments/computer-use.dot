digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Computer Use", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:computer-use" [label="Computer Use", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Agents and frameworks that operate a computer the way a human would (mouse, keyboard, screen)."];
  "cat:computer-use/platform-specific" [label="Platform Specific", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:computer-use/platform-specific/macos" [label="macOS", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:macos-use" [label="macOS-use", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/browser-use/macOS-use", URL="https://github.com/browser-use/macOS-use"];
  "cat:computer-use" -> "cat:computer-use/platform-specific";
  "cat:computer-use/platform-specific" -> "cat:computer-use/platform-specific/macos";
  "cat:computer-use/platform-specific/macos" -> "proj:macos-use";
}