digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Benchmarks", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:benchmarks" [label="Benchmarks", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Standardised benchmarks for evaluating agent and model capabilities."];
  "proj:aicgseceval" [label="AICGSecEval", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Tencent/AICGSecEval", URL="https://github.com/Tencent/AICGSecEval"];
  "proj:osworld" [label="OSWorld", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/xlang-ai/OSWorld", URL="https://github.com/xlang-ai/OSWorld"];
  "cat:benchmarks" -> "proj:aicgseceval";
  "cat:benchmarks" -> "proj:osworld";
}