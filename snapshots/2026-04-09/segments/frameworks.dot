digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Frameworks", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:frameworks" [label="Frameworks", shape=circle, fillcolor="#1f6feb", width=1.55, height=1.55, fontsize=11, tooltip="General-purpose frameworks for building agents and agentic applications."];
  "proj:autogen" [label="autogen", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/microsoft/autogen", URL="https://github.com/microsoft/autogen"];
  "proj:uagents" [label="uAgents", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/fetchai/uAgents", URL="https://github.com/fetchai/uAgents"];
  "proj:ii-agent" [label="ii-agent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Intelligent-Internet/ii-agent", URL="https://github.com/Intelligent-Internet/ii-agent"];
  "proj:agentforge" [label="AgentForge", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/DataBassGit/AgentForge", URL="https://github.com/DataBassGit/AgentForge"];
  "proj:evoagentx" [label="EvoAgentX", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/EvoAgentX/EvoAgentX", URL="https://github.com/EvoAgentX/EvoAgentX"];
  "proj:aiopslab" [label="AIOpsLab", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/microsoft/AIOpsLab", URL="https://github.com/microsoft/AIOpsLab"];
  "cat:frameworks/net" [label=".NET", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:botsharp" [label="BotSharp", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/SciSharp/BotSharp", URL="https://github.com/SciSharp/BotSharp"];
  "cat:frameworks/computer-use" [label="Computer Use", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Agents and frameworks that operate a computer the way a human would (mouse, keyboard, screen)."];
  "proj:agent-s" [label="Agent-S", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/simular-ai/Agent-S", URL="https://github.com/simular-ai/Agent-S"];
  "cat:frameworks/multi-agent" [label="Multi-agent", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:camel" [label="camel", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/camel-ai/camel", URL="https://github.com/camel-ai/camel"];
  "cat:frameworks/multiagent-orchestration" [label="Multiagent Orchestration", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:crewai" [label="crewAI", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/crewAIInc/crewAI", URL="https://github.com/crewAIInc/crewAI"];
  "cat:frameworks/multimodal" [label="Multimodal", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:videosdk-live-agents" [label="videosdk-live/agents", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/videosdk-live/agents", URL="https://github.com/videosdk-live/agents"];
  "cat:frameworks/optimisation" [label="Optimisation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:frameworks/optimisation/parallelisation" [label="Parallelisation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:ensoai" [label="EnsoAI", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/J3n5en/EnsoAI", URL="https://github.com/J3n5en/EnsoAI"];
  "cat:frameworks/social-simulations" [label="Social Simulations", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip=""];
  "proj:concordia" [label="concordia", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/google-deepmind/concordia", URL="https://github.com/google-deepmind/concordia"];
  "proj:moltbook" [label="moltbook", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip=""];
  "cat:frameworks/stateful-design" [label="Stateful Design", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:letta" [label="letta", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/letta-ai/letta", URL="https://github.com/letta-ai/letta"];
  "cat:frameworks/voice" [label="Voice", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Voice-first agents and voice interaction frameworks."];
  "proj:livekit-agents" [label="livekit/agents", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/livekit/agents", URL="https://github.com/livekit/agents"];
  "proj:ten-framework" [label="ten-framework", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/TEN-framework/ten-framework", URL="https://github.com/TEN-framework/ten-framework"];
  "cat:frameworks" -> "proj:autogen";
  "cat:frameworks" -> "proj:uagents";
  "cat:frameworks" -> "proj:ii-agent";
  "cat:frameworks" -> "proj:agentforge";
  "cat:frameworks" -> "proj:evoagentx";
  "cat:frameworks" -> "proj:aiopslab";
  "cat:frameworks" -> "cat:frameworks/net";
  "cat:frameworks/net" -> "proj:botsharp";
  "cat:frameworks" -> "cat:frameworks/computer-use";
  "cat:frameworks/computer-use" -> "proj:agent-s";
  "cat:frameworks" -> "cat:frameworks/multi-agent";
  "cat:frameworks/multi-agent" -> "proj:camel";
  "cat:frameworks" -> "cat:frameworks/multiagent-orchestration";
  "cat:frameworks/multiagent-orchestration" -> "proj:crewai";
  "cat:frameworks" -> "cat:frameworks/multimodal";
  "cat:frameworks/multimodal" -> "proj:videosdk-live-agents";
  "cat:frameworks" -> "cat:frameworks/optimisation";
  "cat:frameworks/optimisation" -> "cat:frameworks/optimisation/parallelisation";
  "cat:frameworks/optimisation/parallelisation" -> "proj:ensoai";
  "cat:frameworks" -> "cat:frameworks/social-simulations";
  "cat:frameworks/social-simulations" -> "proj:concordia";
  "cat:frameworks/social-simulations" -> "proj:moltbook";
  "cat:frameworks" -> "cat:frameworks/stateful-design";
  "cat:frameworks/stateful-design" -> "proj:letta";
  "cat:frameworks" -> "cat:frameworks/voice";
  "cat:frameworks/voice" -> "proj:livekit-agents";
  "cat:frameworks/voice" -> "proj:ten-framework";
}