digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Memory", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:memory" [label="Memory", shape=circle, fillcolor="#6aa9ff", width=0.99, height=0.99, fontsize=10, tooltip="Memory systems for agents — short-term, long-term, episodic, file-backed, graph-backed."];
  "proj:cognee" [label="Cognee", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/topoteretes/cognee", URL="https://github.com/topoteretes/cognee"];
  "proj:agentmemory" [label="AgentMemory", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/rohitg00/agentmemory", URL="https://github.com/rohitg00/agentmemory"];
  "proj:mem0" [label="Mem0", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/mem0ai/mem0", URL="https://github.com/mem0ai/mem0"];
  "proj:memos" [label="MemOS", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/MemTensor/MemOS", URL="https://github.com/MemTensor/MemOS"];
  "cat:memory/file" [label="File", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:memvid" [label="Memvid", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/memvid/memvid", URL="https://github.com/memvid/memvid"];
  "cat:memory/regressive" [label="Regressive", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:agentic-context-engine" [label="Agentic Context Engine", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/kayba-ai/agentic-context-engine", URL="https://github.com/kayba-ai/agentic-context-engine"];
  "cat:memory/skills" [label="Skills", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Agent skills ecosystems — registries, bundles, standards, guides and package libraries."];
  "proj:acontext" [label="Acontext", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/memodb-io/Acontext", URL="https://github.com/memodb-io/Acontext"];
  "cat:memory" -> "proj:cognee";
  "cat:memory" -> "proj:agentmemory";
  "cat:memory" -> "proj:mem0";
  "cat:memory" -> "proj:memos";
  "cat:memory" -> "cat:memory/file";
  "cat:memory/file" -> "proj:memvid";
  "cat:memory" -> "cat:memory/regressive";
  "cat:memory/regressive" -> "proj:agentic-context-engine";
  "cat:memory" -> "cat:memory/skills";
  "cat:memory/skills" -> "proj:acontext";
}