digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Desktop GUIs", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:desktop-guis" [label="Desktop GUIs", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Desktop graphical interfaces for interacting with agents."];
  "proj:hello-halo" [label="hello-halo", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/openkursar/hello-halo", URL="https://github.com/openkursar/hello-halo"];
  "cat:desktop-guis" -> "proj:hello-halo";
}