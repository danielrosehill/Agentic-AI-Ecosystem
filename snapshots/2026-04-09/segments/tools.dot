  "cat:tools/model-routing" [label="Model Routing", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:agentic-flow" [label="agentic-flow", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/ruvnet/agentic-flow", URL="https://github.com/ruvnet/agentic-flow"];
  "cat:tools/semantic-search" [label="Semantic Search", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Semantic search tools for agents operating over codebases and local content."];
  "proj:osgrep" [label="osgrep", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Ryandonofrio3/osgrep", URL="https://github.com/Ryandonofrio3/osgrep"];
  "cat:tools/vision-ui" [label="Vision UI", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:ui-venus" [label="UI-Venus", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/inclusionAI/UI-Venus", URL="https://github.com/inclusionAI/UI-Venus"];
  "cat:tools/world-creation" [label="World Creation", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:tools/world-creation/mcp" [label="MCP", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip="Projects in the Model Context Protocol ecosystem — servers, gateways, aggregators, clients."];
  "proj:unreal-engine-mcp" [label="unreal-engine-mcp", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/flopperam/unreal-engine-mcp", URL="https://github.com/flopperam/unreal-engine-mcp"];
