digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Tools", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:tools" [label="Tools", shape=circle, fillcolor="#1f6feb", width=1.55, height=1.55, fontsize=11, tooltip="Utility tools, SDKs and toolkits for building, debugging and extending agentic systems."];
  "proj:vercel-ai" [label="vercel/ai", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/vercel/ai", URL="https://github.com/vercel/ai"];
  "proj:langflow" [label="langflow", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/langflow-ai/langflow", URL="https://github.com/langflow-ai/langflow"];
  "cat:tools/android" [label="Android", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:agent-device" [label="agent-device", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/callstackincubator/agent-device", URL="https://github.com/callstackincubator/agent-device"];
  "cat:tools/browser-utils" [label="Browser Utils", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "cat:tools/browser-utils/sdk" [label="SDK", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:stagehand" [label="stagehand", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/browserbase/stagehand", URL="https://github.com/browserbase/stagehand"];
  "cat:tools/computer-use" [label="Computer Use", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Agents and frameworks that operate a computer the way a human would (mouse, keyboard, screen)."];
  "proj:cua" [label="cua", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/trycua/cua", URL="https://github.com/trycua/cua"];
  "cat:tools/computer-use/cli" [label="CLI", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:usecomputer" [label="usecomputer", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/remorses/usecomputer", URL="https://github.com/remorses/usecomputer"];
  "cat:tools/data-ingestion" [label="Data Ingestion", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:agent-reach" [label="Agent-Reach", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/Panniantong/Agent-Reach", URL="https://github.com/Panniantong/Agent-Reach"];
  "cat:tools/debugging" [label="Debugging", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:vllora" [label="vllora", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/vllora/vllora", URL="https://github.com/vllora/vllora"];
