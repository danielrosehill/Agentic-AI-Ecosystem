digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Platforms", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:platforms" [label="Platforms", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="General platforms that host or enable agentic applications."];
  "cat:platforms/embodied" [label="Embodied", shape=circle, fillcolor="#6aa9ff", width=0.64, height=0.64, fontsize=10, tooltip=""];
  "proj:fairo" [label="Fairo", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/facebookresearch/fairo", URL="https://github.com/facebookresearch/fairo"];
  "cat:platforms" -> "cat:platforms/embodied";
  "cat:platforms/embodied" -> "proj:fairo";
}