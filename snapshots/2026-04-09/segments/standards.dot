digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="Standards", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:standards" [label="Standards", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Proposed and emerging standards across the agentic ecosystem."];
  "cat:standards/emerging-ecosystem-tied" [label="Emerging (Ecosystem-Tied)", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Emerging standards whose adoption is tied to a specific host ecosystem (e.g. a browser engine or platform vendor) rather than being fully vendor-neutral."];
  "proj:webmcp" [label="WebMCP", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://webmcp.dev/", URL="https://webmcp.dev/"];
  "proj:webmcp-chrome-epp" [label="WebMCP (Chrome EPP)", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://developer.chrome.com/blog/webmcp-epp", URL="https://developer.chrome.com/blog/webmcp-epp"];
  "cat:standards/proposed" [label="Proposed", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip=""];
  "proj:gitagent" [label="GitAgent", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/open-gitagent/gitagent", URL="https://github.com/open-gitagent/gitagent"];
  "proj:aiuc-1" [label="AIUC-1", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://www.aiuc-1.com/", URL="https://www.aiuc-1.com/"];
  "cat:standards/ratified" [label="Ratified", shape=circle, fillcolor="#6aa9ff", width=0.78, height=0.78, fontsize=10, tooltip="Standards with a published specification and active governance."];
  "proj:a2a-agent2agent-protocol" [label="A2A (Agent2Agent Protocol)", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://github.com/a2aproject/A2A", URL="https://github.com/a2aproject/A2A"];
  "proj:ag-ui-agent-user-interaction-protocol" [label="AG-UI (Agent User Interaction Protocol)", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://docs.ag-ui.com/introduction", URL="https://docs.ag-ui.com/introduction"];
  "proj:mcp-model-context-protocol" [label="MCP (Model Context Protocol)", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://modelcontextprotocol.io/specification/2025-11-25", URL="https://modelcontextprotocol.io/specification/2025-11-25"];
  "cat:standards" -> "cat:standards/emerging-ecosystem-tied";
  "cat:standards/emerging-ecosystem-tied" -> "proj:webmcp";
  "cat:standards/emerging-ecosystem-tied" -> "proj:webmcp-chrome-epp";
  "cat:standards" -> "cat:standards/proposed";
  "cat:standards/proposed" -> "proj:gitagent";
  "cat:standards/proposed" -> "proj:aiuc-1";
  "cat:standards" -> "cat:standards/ratified";
  "cat:standards/ratified" -> "proj:a2a-agent2agent-protocol";
  "cat:standards/ratified" -> "proj:ag-ui-agent-user-interaction-protocol";
  "cat:standards/ratified" -> "proj:mcp-model-context-protocol";
}