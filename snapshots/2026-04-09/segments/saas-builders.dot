digraph G {
  graph [layout=dot, overlap=false, splines=true, bgcolor="#f7f8fa", fontname="Helvetica", labelloc="t", label="SaaS Builders", fontsize=22, pad=0.4];
  node [fontname="Helvetica", style="filled", penwidth=0, fontcolor="#1a1f2c"];
  edge [color="#c8cfdb", arrowsize=0.5, penwidth=0.8];
  "cat:saas-builders" [label="SaaS Builders", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Hosted SaaS platforms for building agents and agentic workflows, spanning no-code, visual, and code-defined paradigms."];
  "cat:saas-builders/no-code" [label="No Code", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Builders targeted at non-programmers, typically form- and config-driven with minimal visual wiring."];
  "cat:saas-builders/visual-programming" [label="Visual Programming", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Builders where flows are expressed as node-and-edge graphs or canvas-based visual programs."];
  "proj:n8n" [label="n8n", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://n8n.io/", URL="https://n8n.io/"];
  "cat:saas-builders/visual-programming/workflow-focused" [label="Workflow Focused", shape=circle, fillcolor="#6aa9ff", width=0.71, height=0.71, fontsize=10, tooltip="Visual builders oriented around structured, multi-step workflows rather than free-form agents."];
  "proj:gumloop" [label="Gumloop", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://www.gumloop.com/", URL="https://www.gumloop.com/"];
  "proj:mindstudio" [label="MindStudio", shape=diamond, fillcolor="#f59e0b", width=0.40, height=0.40, fontsize=9, tooltip="https://www.mindstudio.ai/", URL="https://www.mindstudio.ai/"];
  "cat:saas-builders/code-defined" [label="Code-Defined", shape=circle, fillcolor="#6aa9ff", width=0.57, height=0.57, fontsize=10, tooltip="Hosted builders where agents and workflows are primarily defined in code (SDK, DSL, or config-as-code)."];
  "cat:saas-builders" -> "cat:saas-builders/no-code";
  "cat:saas-builders" -> "cat:saas-builders/visual-programming";
  "cat:saas-builders/visual-programming" -> "proj:n8n";
  "cat:saas-builders/visual-programming" -> "cat:saas-builders/visual-programming/workflow-focused";
  "cat:saas-builders/visual-programming/workflow-focused" -> "proj:gumloop";
  "cat:saas-builders/visual-programming/workflow-focused" -> "proj:mindstudio";
  "cat:saas-builders" -> "cat:saas-builders/code-defined";
}